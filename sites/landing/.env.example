# Supabase (Settings → API) — mismas claves públicas que la app si compartes proyecto
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare Turnstile — Site Key pública; hostnames = dominio(s) de la landing (apex + www)
VITE_TURNSTILE_SITE_KEY=

# Solo desarrollo: omitir POST a /api/verify-turnstile si no tienes Pages Functions en local
# VITE_TURNSTILE_VERIFY_SKIP=true

# Opcional: URL absoluta del endpoint de verificación si pruebas el front en otro origen
# VITE_TURNSTILE_VERIFY_URL=https://nacionsilver.com/api/verify-turnstile
