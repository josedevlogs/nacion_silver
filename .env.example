# Copiar a .env y rellenar con el proyecto Supabase (Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare Turnstile (login/registro). Site key pública: Turnstile → tu sitio → Site Key
# Sin esta variable el widget no se muestra (útil en local sin CF Pages Functions).
VITE_TURNSTILE_SITE_KEY=

# Solo desarrollo local: si tienes site key pero no el endpoint /api/verify-turnstile, pon true para omitir la verificación servidor.
# VITE_TURNSTILE_VERIFY_SKIP=true

# Opcional: URL absoluta del endpoint de verificación (p. ej. producción) si pruebas el front en otro origen.
# VITE_TURNSTILE_VERIFY_URL=https://tudominio.com/api/verify-turnstile
